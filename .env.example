# ==========================================================
# The Tani Journal — Environment Variables
# Copy this file to `.env` (local) or set these in Vercel dashboard.
# ==========================================================

# ---- MongoDB (REQUIRED) ----
# For local dev: mongodb://localhost:27017
# For Vercel:    grab from MongoDB Atlas -> Connect -> Drivers -> Node.js URI
#                Example: mongodb+srv://user:pass@cluster0.xxx.mongodb.net/?retryWrites=true&w=majority
MONGO_URL=mongodb://localhost:27017
DB_NAME=tani_journal

# ---- Firebase Web SDK (REQUIRED) ----
# From Firebase Console -> Project Settings -> General -> Your apps -> Web app SDK setup
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=

# ---- Admin access (OPTIONAL) ----
# Comma-separated list of emails that see the moderation queue
ADMIN_EMAILS=

# ---- CORS (leave default for Vercel) ----
CORS_ORIGINS=*

# ---- Deployment (Vercel sets this automatically) ----
# Only set manually for local dev if you want to override.
# NEXT_PUBLIC_BASE_URL=https://your-app.vercel.app
